APP_ENV=development
APP_ENABLE_METRICS=true

## VirusTotal API Configuration
## Get your API key from: https://www.virustotal.com/
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3
VIRUSTOTAL_TIMEOUT=15
VIRUSTOTAL_ENABLED=true

## AbuseIPDB API Configuration
## Get your API key from: https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
ABUSEIPDB_BASE_URL=https://api.abuseipdb.com/api/v2
ABUSEIPDB_TIMEOUT=15
ABUSEIPDB_ENABLED=true

## AlienVault OTX API Configuration
## Get your API key from: https://otx.alienvault.com/
OTX_API_KEY=your_otx_api_key_here
OTX_BASE_URL=https://otx.alienvault.com/api/v1
OTX_TIMEOUT=15
OTX_ENABLED=true

## Hybrid Analysis API Configuration
## Get your API key from: https://www.hybrid-analysis.com/
HYBRID_ANALYSIS_API_KEY=your_hybrid_analysis_api_key_here
HYBRID_ANALYSIS_BASE_URL=https://www.hybrid-analysis.com/api/v2
HYBRID_ANALYSIS_TIMEOUT=15
HYBRID_ANALYSIS_ENABLED=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

CACHE_TTL_SECONDS=86400
CACHE_ENABLED=true

GRPC_HOST=0.0.0.0
GRPC_PORT=50052

GRPC_MAX_CONCURRENT_STREAMS=100
GRPC_KEEPALIVE_TIME_MS=30000
GRPC_KEEPALIVE_TIMEOUT_MS=10000

LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_PATH=/var/log/ti-enrichment/service.log

RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10
