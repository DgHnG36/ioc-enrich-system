# IOC API GATEWAY ENVIRONMENT VARIABLES
PORT=8080 # CHANGE THIS

GRPC_CORE_ADDR=localhost:50051 # CHANGE THIS
GRPC_CONNECT_TIMEOUT=5s # CHANGE THIS

REDIS_ADDR=localhost:6379 # CHANGE THIS
REDIS_PASSWORD= # CHANGE THIS IF YOU HAVE A PASSWORD SET
