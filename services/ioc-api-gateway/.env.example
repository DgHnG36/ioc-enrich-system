ALLOWED_ORIGINS=* # CHANGE THIS

RATE_LIMIT_MAX_REQ=100
RATE_LIMIT_WINDOW_SEC=60

HTTP_READ_TIMEOUT=10s # CHANGE THIS
HTTP_WRITE_TIMEOUT=10s # CHANGE THIS
HTTP_IDLE_TIMEOUT=120s # CHANGE THIS
